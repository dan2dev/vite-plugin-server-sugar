{
  "name": "vite-plugin-server-sugar",
  "version": "0.1.2",
  "description": "Vite-first plugin that turns $server() calls into type-safe API endpoints bundled with Bun, with build-only Rollup and Rolldown entrypoints.",
  "$schema": "https://raw.githubusercontent.com/vitejs/vite-plugin-registry/refs/heads/main/data/schema/extended-package-json.schema.json",
  "author": "Danilo Castro <duocraft.tech@gmail.com>",
  "license": "MIT",
  "type": "module",
  "keywords": [
    "vite-plugin",
    "rollup-plugin",
    "rolldown-plugin",
    "vite",
    "rollup",
    "rolldown",
    "bun",
    "server-functions",
    "server",
    "fullstack"
  ],
  "homepage": "https://github.com/dan2dev/vite-plugin-server-sugar#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dan2dev/vite-plugin-server-sugar.git"
  },
  "bugs": {
    "url": "https://github.com/dan2dev/vite-plugin-server-sugar/issues"
  },
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    },
    "./rollup": {
      "import": "./dist/rollup.mjs",
      "types": "./dist/rollup.d.mts"
    },
    "./rolldown": {
      "import": "./dist/rolldown.mjs",
      "types": "./dist/rolldown.d.mts"
    },
    "./server": {
      "types": "./server.d.ts"
    },
    "./ws": {
      "types": "./ws.d.ts"
    },
    "./worker": {
      "types": "./worker.d.ts"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "server.d.ts",
    "THIRD_PARTY_NOTICES.md",
    "ws.d.ts",
    "worker.d.ts"
  ],
  "scripts": {
    "build": "tsdown && cp server.d.ts dist/server.d.ts && cp ws.d.ts dist/ws.d.ts && cp worker.d.ts dist/worker.d.ts",
    "build:watch": "tsdown --watch",
    "check": "bun run typecheck && bun run test && bun run build",
    "dev": "tsdown --watch",
    "test": "vitest --run",
    "test:watch": "vitest",
    "test:coverage": "vitest --run --coverage",
    "test:types": "vitest typecheck --run",
    "typecheck": "tsc --noEmit",
    "release": "bumpp",
    "prepare": "bun run build",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "rolldown": "^1.1.3",
    "typescript": "^6.0.3",
    "ws": "^8.21.0"
  },
  "peerDependencies": {
    "hono": ">=4.0.0",
    "rollup": ">=4.0.0",
    "rolldown": ">=1.0.0",
    "vite": ">=6.0.0"
  },
  "peerDependenciesMeta": {
    "rollup": {
      "optional": true
    },
    "rolldown": {
      "optional": true
    },
    "vite": {
      "optional": true
    }
  },
  "compatiblePackages": {
    "schemaVersion": 1,
    "vite": {
      "type": "compatible",
      "versions": ">=6.0.0",
      "note": "Primary integration. The default entrypoint includes Vite config, dev-server middleware, HMR invalidation, and production server generation."
    },
    "rollup": {
      "type": "compatible",
      "versions": ">=4.0.0",
      "note": "Use vite-plugin-server-sugar/rollup. Rollup support is build-only; Vite dev-server middleware and HMR are not available."
    },
    "rolldown": {
      "type": "compatible",
      "versions": ">=1.0.0",
      "note": "Use vite-plugin-server-sugar/rolldown. Rolldown support is build-only; Vite dev-server middleware and HMR are not available."
    }
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.1.9",
    "bumpp": "^11.1.0",
    "bun-types": "^1.3.14",
    "fast-check": "^4.8.0",
    "hono": "^4.12.27",
    "tsdown": "^0.22.3",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  }
}
