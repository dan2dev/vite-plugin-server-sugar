{
  "name": "vite-plugin-server-build",
  "version": "0.1.0",
  "description": "Vite plugin that turns $action() calls into type-safe API endpoints bundled with Bun.",
  "author": "Danilo Castro <duocraft.tech@gmail.com>",
  "license": "MIT",
  "type": "module",
  "keywords": [
    "vite-plugin",
    "vite",
    "bun",
    "server-functions",
    "action",
    "fullstack"
  ],
  "homepage": "https://github.com/dan2dev/vite-plugin-server-build#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dan2dev/vite-plugin-server-build.git"
  },
  "bugs": {
    "url": "https://github.com/dan2dev/vite-plugin-server-build/issues"
  },
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    },
    "./action": {
      "types": "./action.d.ts"
    },
    "./ws": {
      "types": "./ws.d.ts"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "action.d.ts",
    "ws.d.ts"
  ],
  "scripts": {
    "build": "tsdown && cp action.d.ts dist/action.d.ts && cp ws.d.ts dist/ws.d.ts",
    "build:watch": "tsdown --watch",
    "dev": "tsdown --watch",
    "test": "vitest --run",
    "test:watch": "vitest",
    "test:coverage": "vitest --run --coverage",
    "test:types": "vitest typecheck --run",
    "typecheck": "tsc --noEmit",
    "release": "bumpp",
    "prepare": "bun run build",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "rolldown": "^1.1.1",
    "typescript": "^6.0.3",
    "ws": "^8.18.0"
  },
  "peerDependencies": {
    "hono": ">=4.0.0",
    "vite": ">=6.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.21",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.1.9",
    "bumpp": "^11.1.0",
    "bun-types": "^1.3.14",
    "fast-check": "^4.8.0",
    "hono": "^4.7.4",
    "tsdown": "^0.22.2",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  }
}
